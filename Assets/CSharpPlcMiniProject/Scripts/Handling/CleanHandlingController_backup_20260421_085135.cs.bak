// 박스 컨베이어 컨트롤러를 참조하기 위한 네임스페이스입니다.
using CSharpPlcMiniProject.BoxLine;
// realvirtual의 PLC 신호 타입과 ControlLogic 기반 클래스를 사용하기 위한 네임스페이스입니다.
using realvirtual;
// Unity의 Time, Mathf, Resources, Component 같은 기능을 사용하기 위한 네임스페이스입니다.
using UnityEngine;

// 핸들링 장치 제어 코드를 프로젝트 전용 네임스페이스로 묶습니다.
namespace CSharpPlcMiniProject.Handling
{
    // 씬에서 이 컴포넌트를 선택하면 루트 오브젝트가 선택되도록 돕는 Unity 속성입니다.
    [SelectionBase]
    // 캔을 집어서 박스에 넣는 gantry 핸들링 장치를 PLC 시퀀스처럼 제어하는 클래스입니다.
    public sealed class CleanHandlingController : ControlLogic
    {
        // 인스펙터에서 동작 모드 관련 필드를 묶어 보여줍니다.
        [Header("Mode")]
        // 이 컨트롤러를 동작시킬지 끌지 결정하는 수동 활성화 플래그입니다.
        public bool isEnabled = true;

        // 인스펙터에서 Y축 관련 PLC 신호들을 묶어 보여줍니다.
        [Header("Y Axis")]
        // Y축 목표 위치를 쓰는 PLC 출력 신호입니다.
        public PLCOutputFloat gantryYDestination;
        // Y축 이동 시작 펄스를 쓰는 PLC 출력 신호입니다.
        public PLCOutputBool gantryYStart;
        // Y축이 목표 위치에 도착했는지 읽는 PLC 입력 신호입니다.
        public PLCInputBool gantryYAtDestination;
        // Y축이 현재 이동 중인지 읽는 PLC 입력 신호입니다.
        public PLCInputBool gantryYDriving;
        // Y축의 현재 위치 값을 읽는 PLC 입력 신호입니다.
        public PLCInputFloat gantryYCurrentPosition;

        // 인스펙터에서 Z축 관련 PLC 신호들을 묶어 보여줍니다.
        [Header("Z Axis")]
        // Z축 목표 위치를 쓰는 PLC 출력 신호입니다.
        public PLCOutputFloat gantryZDestination;
        // Z축 이동 시작 펄스를 쓰는 PLC 출력 신호입니다.
        public PLCOutputBool gantryZStart;
        // Z축이 목표 위치에 도착했는지 읽는 PLC 입력 신호입니다.
        public PLCInputBool gantryZAtDestination;
        // Z축이 현재 이동 중인지 읽는 PLC 입력 신호입니다.
        public PLCInputBool gantryZDriving;
        // Z축의 현재 위치 값을 읽는 PLC 입력 신호입니다.
        public PLCInputFloat gantryZCurrentPosition;

        // 인스펙터에서 그리퍼 관련 PLC 신호들을 묶어 보여줍니다.
        [Header("Gripper")]
        // 그리퍼 열기 명령을 쓰는 PLC 출력 신호입니다.
        public PLCOutputBool openGripper;
        // 그리퍼 닫기 명령을 쓰는 PLC 출력 신호입니다.
        public PLCOutputBool closeGripper;
        // 그리퍼가 열렸는지 읽는 PLC 입력 신호입니다.
        public PLCInputBool gripperOpened;
        // 그리퍼가 닫혔는지 읽는 PLC 입력 신호입니다.
        public PLCInputBool gripperClosed;

        // 인스펙터에서 센서와 HMI 관련 신호들을 묶어 보여줍니다.
        [Header("Sensors and HMI")]
        // 픽업 위치에 캔이 도착했는지 읽는 PLC 입력 신호입니다.
        public PLCInputBool sensorCan;
        // 박스 교체 사이클을 수동으로 시작하는 버튼 입력 신호입니다.
        public PLCInputBool buttonStartChangeCycle;
        // 핸들링 장치 자동 운전을 허용하는 버튼 입력 신호입니다.
        public PLCInputBool buttonHandlingOn;

        // 관련된 다른 PLC 컨트롤러 참조를 묶어 보여줍니다.
        [Header("Related PLC Controllers")]
        // 박스 준비 상태와 행 이동 요청을 주고받기 위한 박스 컨베이어 컨트롤러입니다.
        public CleanBoxConveyorController boxConveyor;

        // 인스펙터에서 핸들링 위치 설정값들을 묶어 보여줍니다.
        [Header("Positions")]
        // 캔을 집는 Y축 위치입니다.
        public float pickCanPosY;
        // 캔을 집는 Z축 위치입니다.
        public float pickCanPosZ;
        // 캔을 내려놓는 시작 Y축 위치입니다.
        public float placeCanPosY;
        // 캔을 내려놓는 Z축 위치입니다.
        public float placeCanPosZ;
        // 캔을 들고 이동할 때 사용하는 안전 Z축 위치입니다.
        public float transportCanPosZ;

        // 인스펙터에서 박스 적재 패턴 설정값들을 묶어 보여줍니다.
        [Header("Box Pattern")]
        // 박스에 적재할 행 수입니다.
        public int numberOfRows = 2;
        // 박스에 적재할 열 수입니다.
        public int numberOfColumns = 5;
        // 같은 행에서 다음 열로 이동할 Y축 거리입니다.
        public float distanceColumn = 100f;
        // 다음 행으로 이동할 박스 컨베이어 이동 거리입니다.
        public float distanceRow = 100f;

        // 인스펙터에서 현재 상태와 디버그 정보를 묶어 보여줍니다.
        [Header("Status")]
        // 핸들링 장치의 현재 시퀀스 단계를 표시합니다.
        public HandlingStep currentStep = HandlingStep.WaitingForCan;
        // 현재 적재 중인 박스 행 번호입니다.
        public int currentRowNumber = 1;
        // 현재 적재 중인 박스 열 번호입니다.
        public int currentColumnNumber = 1;
        // 완료한 캔 적재 사이클 수입니다.
        public int cycleNumber;
        // 현재 단계에서 기다리는 이유를 문자열로 표시합니다.
        public string waitReason;
        // 마지막으로 축에 내린 이동 명령을 문자열로 표시합니다.
        public string lastCommand;
        public string lastCommandSource;
        public int commandNumber;
        // 로더가 현재 목표 위치에 도착했다고 판단했는지 표시합니다.
        public bool loaderAtDestinationStatus;
        // 박스가 캔을 받을 준비가 되었다고 판단했는지 표시합니다.
        public bool boxReadyForPlacingStatus;
        // 박스가 gantry 투입 위치 센서에 감지되는지 표시합니다.
        public bool boxGantryOccupiedStatus;
        // 박스 컨베이어가 현재 구동 중인지 표시합니다.
        public bool boxConveyorRunningStatus;
        // 디버그용 Y축 현재 위치입니다.
        public float gantryYPositionStatus;
        // 디버그용 Z축 현재 위치입니다.
        public float gantryZPositionStatus;
        // 디버그용 Y축 목표 위치입니다.
        public float targetYPositionStatus;
        // 디버그용 Z축 목표 위치입니다.
        public float targetZPositionStatus;
        // 실제 GantryYDestination PLC 출력 신호에 기록된 값입니다.
        public float gantryYDestinationSignalStatus;
        // 실제 GantryZDestination PLC 출력 신호에 기록된 값입니다.
        public float gantryZDestinationSignalStatus;
        // 실제 GantryYStart PLC 출력 신호가 켜져 있는지 표시합니다.
        public bool gantryYStartSignalStatus;
        // 실제 GantryZStart PLC 출력 신호가 켜져 있는지 표시합니다.
        public bool gantryZStartSignalStatus;
        // 실제 GantryYDriving PLC 입력 신호가 켜져 있는지 표시합니다.
        public bool gantryYDrivingSignalStatus;
        // 실제 GantryZDriving PLC 입력 신호가 켜져 있는지 표시합니다.
        public bool gantryZDrivingSignalStatus;
        // 실제 GantryYAtDestination PLC 입력 신호가 켜져 있는지 표시합니다.
        public bool gantryYAtDestinationSignalStatus;
        // 실제 GantryZAtDestination PLC 입력 신호가 켜져 있는지 표시합니다.
        public bool gantryZAtDestinationSignalStatus;
        // realvirtual Y축 Drive 컴포넌트 참조입니다.
        public Drive gantryYDrive;
        // realvirtual Z축 Drive 컴포넌트 참조입니다.
        public Drive gantryZDrive;
        // Y축 Drive 본체에 들어간 TargetPosition 값입니다.
        public float gantryYDriveTargetPositionStatus;
        // Z축 Drive 본체에 들어간 TargetPosition 값입니다.
        public float gantryZDriveTargetPositionStatus;
        // Y축 Drive 본체의 TargetStartMove 상태입니다.
        public bool gantryYDriveTargetStartStatus;
        // Z축 Drive 본체의 TargetStartMove 상태입니다.
        public bool gantryZDriveTargetStartStatus;
        // Y축 Drive 본체의 IsRunning 상태입니다.
        public bool gantryYDriveIsRunningStatus;
        // Z축 Drive 본체의 IsRunning 상태입니다.
        public bool gantryZDriveIsRunningStatus;
        // Y축 Drive 본체의 IsAtTarget 상태입니다.
        public bool gantryYDriveIsAtTargetStatus;
        // Z축 Drive 본체의 IsAtTarget 상태입니다.
        public bool gantryZDriveIsAtTargetStatus;
        // Y축 Drive 본체의 BlockDestination 상태입니다.
        public bool gantryYDriveBlockDestinationStatus;
        // Z축 Drive 본체의 BlockDestination 상태입니다.
        public bool gantryZDriveBlockDestinationStatus;
        public string gantryYDrivePathStatus;
        public string gantryZDrivePathStatus;
        public bool gantryYDriveSmoothAccelerationStatus;
        public bool gantryZDriveSmoothAccelerationStatus;
        // 현재 이동 명령 중 Y축 Start 신호를 한 번이라도 감지했는지 표시합니다.
        public bool gantryYStartSeenThisMove;
        // 현재 이동 명령 중 Z축 Start 신호를 한 번이라도 감지했는지 표시합니다.
        public bool gantryZStartSeenThisMove;
        // 현재 이동 명령 중 Y축 Driving 신호를 한 번이라도 감지했는지 표시합니다.
        public bool gantryYDrivingSeenThisMove;
        // 현재 이동 명령 중 Z축 Driving 신호를 한 번이라도 감지했는지 표시합니다.
        public bool gantryZDrivingSeenThisMove;

        // 이동 시작 신호를 펄스로 유지할 시간입니다.
        [SerializeField] private float driveStartPulseSeconds = 0.5f;
        // 캔을 놓은 뒤 그리퍼 열림 상태를 안정적으로 기다리는 시간입니다.
        [SerializeField] private float releaseDelaySeconds = 0.9f;
        // 이동 피드백이 늦게 들어오는 경우를 고려한 최소 대기 시간입니다.
        [SerializeField] private float moveFeedbackGraceSeconds = 0.8f;
        // 새 이동 명령이 Drive와 PLC 신호에 반영될 최소 시간입니다.
        [SerializeField] private float commandSettleSeconds = 0.05f;
        // 현재 위치와 목표 위치를 비교할 때 허용하는 위치 오차입니다.
        [SerializeField] private float positionTolerance = 2.0f;

        // 현재 캔을 내려놓을 Y축 위치를 계산해 저장합니다.
        private float placePositionY;
        // 그리퍼 열림 지연 시간을 계산하기 위한 시작 시간입니다.
        private float releaseStartedAt;
        // 축 이동 명령을 내린 시각입니다.
        private float moveStartedAt;
        // 현재 이동 명령의 Y축 목표 위치입니다.
        private float targetPositionY;
        // 현재 이동 명령의 Z축 목표 위치입니다.
        private float targetPositionZ;
        // 축 이동 중 신호가 한 번이라도 켜졌는지 기억하는 내부 플래그입니다.
        private bool sawDriveMoving;

        // 컴포넌트가 로드될 때 누락된 PLC 신호를 자동으로 찾아 연결합니다.
        private void Awake()
        {
            // 인스펙터 연결이 비어 있는 신호를 씬에서 이름으로 다시 찾습니다.
            ResolveMissingSignals();
        }

        // 컴포넌트가 시작될 때 한 번 실행되는 초기화 메서드입니다.
        private void Start()
        {
            // Play 시작 시점에도 누락된 PLC 신호를 한 번 더 확인합니다.
            ResolveMissingSignals();
            // 시작 상태를 캔 대기 단계로 초기화합니다.
            currentStep = HandlingStep.WaitingForCan;
            // 시작 행 번호를 1로 초기화합니다.
            currentRowNumber = 1;
            // 시작 열 번호를 1로 초기화합니다.
            currentColumnNumber = 1;
            // 완료 사이클 수를 0으로 초기화합니다.
            cycleNumber = 0;
            // 그리퍼 열림 지연 타이머를 초기화합니다.
            releaseStartedAt = 0f;
            // 시작 시 그리퍼를 열어 둡니다.
            Set(openGripper, true);
            // 시작 시 그리퍼 닫기 명령은 꺼둡니다.
            Set(closeGripper, false);
        }

        // 인스펙터에서 빠진 PLC 신호를 씬 오브젝트 이름으로 찾아 채우는 메서드입니다.
        private void ResolveMissingSignals()
        {
            if (gantryYDrive == null)
            {
                gantryYDrive = FindSceneDrive("GantryY");
            }

            if (gantryZDrive == null)
            {
                gantryZDrive = FindSceneDrive("GantryZ");
            }

            ConfigureDriveForDemo(gantryYDrive);
            ConfigureDriveForDemo(gantryZDrive);

            // Y축 이동 중 신호가 비어 있으면 씬에서 찾아 연결합니다.
            if (gantryYDriving == null)
            {
                // 이름이 GantryYDriving인 PLCInputBool 컴포넌트를 찾습니다.
                gantryYDriving = FindSceneSignal<PLCInputBool>("GantryYDriving");
            }

            // Y축 현재 위치 신호가 비어 있으면 씬에서 찾아 연결합니다.
            if (gantryYCurrentPosition == null)
            {
                // 이름이 GantryYCurrentPosition인 PLCInputFloat 컴포넌트를 찾습니다.
                gantryYCurrentPosition = FindSceneSignal<PLCInputFloat>("GantryYCurrentPosition");
            }

            // Z축 이동 중 신호가 비어 있으면 씬에서 찾아 연결합니다.
            if (gantryZDriving == null)
            {
                // 이름이 GantryZDriving인 PLCInputBool 컴포넌트를 찾습니다.
                gantryZDriving = FindSceneSignal<PLCInputBool>("GantryZDriving");
            }

            // Z축 현재 위치 신호가 비어 있으면 씬에서 찾아 연결합니다.
            if (gantryZCurrentPosition == null)
            {
                // 이름이 GantryZCurrentPosition인 PLCInputFloat 컴포넌트를 찾습니다.
                gantryZCurrentPosition = FindSceneSignal<PLCInputFloat>("GantryZCurrentPosition");
            }
        }

        // Unity 물리 주기에 맞춰 반복 실행되는 제어 루프입니다.
        private void FixedUpdate()
        {
            // 인스펙터에서 실제 PLC 신호값을 실시간으로 볼 수 있도록 먼저 갱신합니다.
            UpdateSignalDebugStatus();

            // 비상정지 상태이거나, 컨트롤러가 꺼져 있거나, HMI에서 핸들링 운전이 허용되지 않으면 중지합니다.
            if (ForceStop || !isEnabled || !HandlingAllowed())
            {
                // 현재 주기에서는 아무 동작도 하지 않고 빠져나갑니다.
                return;
            }

            // 수동 박스 교체 버튼이 연결되어 있고 눌려 있으면 박스 교체 사이클을 시작합니다.
            if (buttonStartChangeCycle != null && buttonStartChangeCycle.Value)
            {
                // 행/열 번호를 초기화하고 박스 교체 요청을 켭니다.
                StartBoxChangeCycle();
            }

            // 현재 상태에 맞는 핸들링 시퀀스를 실행합니다.
            RunStep();

            // 이번 제어 주기에서 신호를 변경했을 수 있으므로 한 번 더 갱신합니다.
            UpdateSignalDebugStatus();
        }

        // HMI 핸들링 운전 허용 조건을 확인하는 메서드입니다.
        private bool HandlingAllowed()
        {
            // 버튼 신호가 없으면 항상 허용으로 보고, 신호가 있으면 버튼 값을 따릅니다.
            return buttonHandlingOn == null || buttonHandlingOn.Value;
        }

        // 현재 HandlingStep에 따라 핸들링 시퀀스를 진행하는 상태 머신입니다.
        private void RunStep()
        {
            // 이번 주기에서 새 대기 사유를 기록하기 위해 문자열을 초기화합니다.
            waitReason = "";

            // 현재 단계에 따라 실행할 로직을 선택합니다.
            switch (currentStep)
            {
                // 캔이 픽업 위치에 도착하기를 기다리는 단계입니다.
                case HandlingStep.WaitingForCan:
                    // 캔 센서가 ON이면 픽업 동작을 시작합니다.
                    if (IsOn(sensorCan))
                    {
                        // 캔을 잡기 전 그리퍼를 열어 둡니다.
                        Set(openGripper, true);
                        // 캔을 잡기 전 그리퍼 닫기 명령은 꺼둡니다.
                        Set(closeGripper, false);
                        // gantry를 캔 픽업 위치로 이동시킵니다.
                        MoveLoaderTo(pickCanPosY, pickCanPosZ, "WaitingForCan -> MoveToPick");
                        // 픽업 위치 도착 대기 단계로 이동합니다.
                        currentStep = HandlingStep.MoveToPick;
                    }

                    // 이 case 처리를 종료합니다.
                    break;

                // gantry가 캔 픽업 위치로 이동 중인 단계입니다.
                case HandlingStep.MoveToPick:
                    // Y/Z축이 목표 위치에 도착했는지 확인합니다.
                    if (LoaderAtDestination())
                    {
                        // 그리퍼 열기 명령을 끕니다.
                        Set(openGripper, false);
                        // 그리퍼 닫기 명령을 켭니다.
                        Set(closeGripper, true);
                        // 그리퍼 닫힘 대기 단계로 이동합니다.
                        currentStep = HandlingStep.CloseGripper;
                    }
                    else
                    {
                        // 아직 도착하지 않았다면 디버그용 대기 사유를 기록합니다.
                        waitReason = "Waiting pick position. " + BuildMoveDebugText();
                    }

                    // 이 case 처리를 종료합니다.
                    break;

                // 그리퍼가 캔을 잡을 때까지 기다리는 단계입니다.
                case HandlingStep.CloseGripper:
                    // 그리퍼 닫힘 센서가 ON인지 확인합니다.
                    if (IsOn(gripperClosed))
                    {
                        // 캔을 들고 이동하기 위해 안전 높이로 들어 올립니다.
                        MoveLoaderTo(pickCanPosY, transportCanPosZ, "CloseGripper -> LiftCan");
                        // 캔 들어올림 완료 대기 단계로 이동합니다.
                        currentStep = HandlingStep.LiftCan;
                    }
                    else
                    {
                        // 아직 그리퍼가 닫히지 않았다면 대기 사유를 기록합니다.
                        waitReason = "Waiting gripper closed.";
                    }

                    // 이 case 처리를 종료합니다.
                    break;

                // 캔을 잡은 뒤 안전 높이로 들어 올리는 단계입니다.
                case HandlingStep.LiftCan:
                    // Y/Z축이 안전 높이에 도착했는지 확인합니다.
                    if (LoaderAtDestination())
                    {
                        // 현재 열 번호에 따라 이번 캔을 내려놓을 Y축 위치를 계산합니다.
                        placePositionY = placeCanPosY + (currentColumnNumber - 1) * distanceColumn;
                        // 계산된 Y 위치와 안전 Z 위치로 수평 이동합니다.
                        MoveLoaderTo(placePositionY, transportCanPosZ, "LiftCan -> MoveToPlace");
                        // 박스 위 배치 위치 이동 단계로 넘어갑니다.
                        currentStep = HandlingStep.MoveToPlace;
                    }
                    else
                    {
                        // 아직 들어올림이 끝나지 않았다면 대기 사유를 기록합니다.
                        waitReason = "Waiting lift complete. " + BuildMoveDebugText();
                    }

                    // 이 case 처리를 종료합니다.
                    break;

                // 캔을 들고 박스 위 배치 위치로 이동하는 단계입니다.
                case HandlingStep.MoveToPlace:
                    // gantry가 목표 위치에 도착했는지 계산합니다.
                    bool loaderAtPlace = LoaderAtDestination();
                    // 박스가 캔을 받을 준비가 되었는지 계산합니다.
                    bool boxReady = BoxIsReadyForPlacing();
                    // gantry 도착과 박스 준비가 모두 만족되면 내려놓기 동작을 시작합니다.
                    if (loaderAtPlace && boxReady)
                    {
                        // 현재 Y 위치를 유지하고 캔을 놓을 Z 위치로 내려갑니다.
                        MoveLoaderTo(placePositionY, placeCanPosZ, "MoveToPlace -> LowerToPlace");
                        // 캔 내려놓기 위치 도착 대기 단계로 이동합니다.
                        currentStep = HandlingStep.LowerToPlace;
                    }
                    else
                    {
                        // gantry가 아직 도착하지 않았으면 위치 대기 메시지를 기록합니다.
                        waitReason = !loaderAtPlace
                            ? "Waiting place position. " + BuildMoveDebugText()
                            // gantry는 도착했지만 박스가 준비되지 않았으면 박스 조건 대기 메시지를 기록합니다.
                            : "Waiting box ready. BoxGantry=" + boxGantryOccupiedStatus
                              + ", BoxConvRun=" + boxConveyorRunningStatus;
                    }

                    // 이 case 처리를 종료합니다.
                    break;

                // 캔을 박스 안으로 내리는 단계입니다.
                case HandlingStep.LowerToPlace:
                    // Y/Z축이 내려놓기 위치에 도착했는지 확인합니다.
                    if (LoaderAtDestination())
                    {
                        // 캔을 놓기 위해 그리퍼 열기 명령을 켭니다.
                        Set(openGripper, true);
                        // 캔을 놓기 위해 그리퍼 닫기 명령을 끕니다.
                        Set(closeGripper, false);
                        // 그리퍼 열림 지연 타이머를 초기화합니다.
                        releaseStartedAt = 0f;
                        // 그리퍼 열림 대기 단계로 이동합니다.
                        currentStep = HandlingStep.OpenGripper;
                    }
                    else
                    {
                        // 아직 내려놓기 위치에 도착하지 않았다면 대기 사유를 기록합니다.
                        waitReason = "Waiting lower complete. " + BuildMoveDebugText();
                    }

                    // 이 case 처리를 종료합니다.
                    break;

                // 그리퍼를 열어 캔을 놓는 단계입니다.
                case HandlingStep.OpenGripper:
                    // 그리퍼 열림 센서가 ON이고 안정화 지연 시간이 지났는지 확인합니다.
                    if (IsOn(gripperOpened) && DelayElapsed(ref releaseStartedAt, releaseDelaySeconds))
                    {
                        // 캔을 놓은 뒤 다시 안전 높이로 올라갑니다.
                        MoveLoaderTo(placePositionY, transportCanPosZ, "OpenGripper -> LiftAfterPlace");
                        // 놓은 뒤 들어올림 단계로 이동합니다.
                        currentStep = HandlingStep.LiftAfterPlace;
                    }
                    else
                    {
                        // 아직 그리퍼가 열리지 않았거나 지연 시간이 끝나지 않았다면 대기 사유를 기록합니다.
                        waitReason = "Waiting gripper opened or release delay.";
                    }

                    // 이 case 처리를 종료합니다.
                    break;

                // 캔을 놓은 뒤 안전 높이로 올라가는 단계입니다.
                case HandlingStep.LiftAfterPlace:
                    // Y/Z축이 안전 높이에 도착했는지 확인합니다.
                    if (LoaderAtDestination())
                    {
                        // 다음 캔을 기다리기 위해 픽업 Y 위치와 안전 Z 위치로 이동합니다.
                        MoveLoaderTo(pickCanPosY, transportCanPosZ, "LiftAfterPlace -> ReturnToWaitPosition");
                        // 박스 적재 패턴의 다음 열 또는 다음 행으로 진행합니다.
                        AdvanceBoxPattern();
                        // 대기 위치 복귀 단계로 이동합니다.
                        currentStep = HandlingStep.ReturnToWaitPosition;
                    }
                    else
                    {
                        // 아직 들어올림이 끝나지 않았다면 대기 사유를 기록합니다.
                        waitReason = "Waiting lift after place. " + BuildMoveDebugText();
                    }

                    // 이 case 처리를 종료합니다.
                    break;

                // 다음 캔을 기다리는 위치로 복귀하는 단계입니다.
                case HandlingStep.ReturnToWaitPosition:
                    // Y/Z축이 대기 위치에 도착했는지 확인합니다.
                    if (LoaderAtDestination())
                    {
                        // 다시 캔 감지 대기 단계로 돌아갑니다.
                        currentStep = HandlingStep.WaitingForCan;
                    }
                    else
                    {
                        // 아직 복귀하지 않았다면 대기 사유를 기록합니다.
                        waitReason = "Waiting return position. " + BuildMoveDebugText();
                    }

                    // 이 case 처리를 종료합니다.
                    break;
            }
        }

        // gantry Y/Z축에 이동 명령을 내리는 메서드입니다.
        private void MoveLoaderTo(float positionY, float positionZ, string commandSource = "")
        {
            // 이전 이동 명령에서 예약된 Start 신호 리셋 호출이 있으면 취소합니다.
            CancelInvoke(nameof(ResetDriveStartSignals));
            // 이동 명령을 내린 현재 시간을 저장합니다.
            moveStartedAt = Time.time;
            // 현재 이동 명령의 Y축 목표 위치를 저장합니다.
            targetPositionY = positionY;
            // 현재 이동 명령의 Z축 목표 위치를 저장합니다.
            targetPositionZ = positionZ;
            // 이동 중 피드백 감지 플래그를 초기화합니다.
            sawDriveMoving = false;
            // 이번 이동 명령에서 Y축 Start를 감지했는지 초기화합니다.
            gantryYStartSeenThisMove = false;
            // 이번 이동 명령에서 Z축 Start를 감지했는지 초기화합니다.
            gantryZStartSeenThisMove = false;
            // 이번 이동 명령에서 Y축 Driving을 감지했는지 초기화합니다.
            gantryYDrivingSeenThisMove = false;
            // 이번 이동 명령에서 Z축 Driving을 감지했는지 초기화합니다.
            gantryZDrivingSeenThisMove = false;
            // 인스펙터에서 볼 수 있도록 마지막 이동 명령을 문자열로 기록합니다.
            lastCommand = "Move Y=" + positionY.ToString("0.0") + ", Z=" + positionZ.ToString("0.0");
            lastCommandSource = commandSource;
            commandNumber++;
            // Y축 목표 위치 출력에 값을 씁니다.
            Set(gantryYDestination, positionY);
            // Z축 목표 위치 출력에 값을 씁니다.
            Set(gantryZDestination, positionZ);
            // Y축 이동 시작 펄스를 켭니다.
            Set(gantryYStart, true);
            // Z축 이동 시작 펄스를 켭니다.
            Set(gantryZStart, true);
            StartDriveDirectly(gantryYDrive, positionY);
            StartDriveDirectly(gantryZDrive, positionZ);
            // 일정 시간이 지난 뒤 Start 신호를 자동으로 끄도록 예약합니다.
            Invoke(nameof(ResetDriveStartSignals), driveStartPulseSeconds);
        }

        // 이동 시작 펄스를 끄는 메서드입니다.
        private static void StartDriveDirectly(Drive drive, float targetPosition)
        {
            if (drive == null)
            {
                return;
            }

            drive.DriveTo(targetPosition);
        }

        private void ResetDriveStartSignals()
        {
            // Y축 이동 시작 신호를 끕니다.
            Set(gantryYStart, false);
            // Z축 이동 시작 신호를 끕니다.
            Set(gantryZStart, false);
        }

        // gantry Y/Z축이 현재 목표 위치에 도착했는지 판단하는 메서드입니다.
        private bool LoaderAtDestination()
        {
            bool commandSettled = Time.time - moveStartedAt >= commandSettleSeconds;
            // 이동 시작 펄스가 모두 꺼졌는지 확인합니다.
            bool startPulseFinished = !IsOn(gantryYStart) && !IsOn(gantryZStart);
            // Y/Z축이 둘 다 이동 중이 아닌지 확인합니다.
            bool yAxisReady;
            // 이동 명령 후 최소 대기 시간이 지났는지 확인합니다.
            bool zAxisReady;
            // Y/Z축 위치 피드백이 모두 목표에 도달했는지 확인합니다.
            yAxisReady = AxisAtTarget(gantryYDrive, gantryYAtDestination, gantryYCurrentPosition, targetPositionY);
            zAxisReady = AxisAtTarget(gantryZDrive, gantryZAtDestination, gantryZCurrentPosition, targetPositionZ);

            // 인스펙터 확인용 Y축 현재 위치를 갱신합니다.
            gantryYPositionStatus = Value(gantryYCurrentPosition);
            // 인스펙터 확인용 Z축 현재 위치를 갱신합니다.
            gantryZPositionStatus = Value(gantryZCurrentPosition);
            // 인스펙터 확인용 Y축 목표 위치를 갱신합니다.
            targetYPositionStatus = targetPositionY;
            // 인스펙터 확인용 Z축 목표 위치를 갱신합니다.
            targetZPositionStatus = targetPositionZ;
            // 인스펙터 확인용 박스 gantry 위치 센서 상태를 갱신합니다.
            boxGantryOccupiedStatus = IsOn(boxConveyor != null ? boxConveyor.sensorGantryOccupied : null);
            // 인스펙터 확인용 박스 컨베이어 구동 상태를 갱신합니다.
            boxConveyorRunningStatus = IsOn(boxConveyor != null ? boxConveyor.startConveyor : null);
            // 인스펙터 확인용 박스 준비 상태를 갱신합니다.
            boxReadyForPlacingStatus = BoxIsReadyForPlacing();
            // 인스펙터 확인용 실제 PLC 신호 상태를 갱신합니다.
            UpdateSignalDebugStatus();

            // Y축이나 Z축이 이동 중이면 한 번이라도 이동 피드백을 봤다고 기록합니다.
            if (IsOn(gantryYDriving) || IsOn(gantryZDriving))
            {
                // 이동 피드백 감지 플래그를 켭니다.
                sawDriveMoving = true;
            }

            // 시작 펄스가 끝났고 도착 피드백, 위치 피드백, 또는 이동 종료 피드백 중 하나가 만족되면 도착으로 판단합니다.
            loaderAtDestinationStatus = commandSettled && startPulseFinished && yAxisReady && zAxisReady;
            // 계산된 도착 상태를 반환합니다.
            return loaderAtDestinationStatus;
        }

        // 실제 PLC 입력/출력 신호에 들어간 값을 인스펙터 표시용 필드로 복사하는 메서드입니다.
        private void UpdateSignalDebugStatus()
        {
            // 실제 Y축 목표 위치 출력 신호 값을 표시합니다.
            gantryYDestinationSignalStatus = Value(gantryYDestination);
            // 실제 Z축 목표 위치 출력 신호 값을 표시합니다.
            gantryZDestinationSignalStatus = Value(gantryZDestination);
            // 실제 Y축 시작 출력 신호 상태를 표시합니다.
            gantryYStartSignalStatus = IsOn(gantryYStart);
            // 실제 Z축 시작 출력 신호 상태를 표시합니다.
            gantryZStartSignalStatus = IsOn(gantryZStart);
            // 실제 Y축 이동 중 입력 신호 상태를 표시합니다.
            gantryYDrivingSignalStatus = IsOn(gantryYDriving);
            // 실제 Z축 이동 중 입력 신호 상태를 표시합니다.
            gantryZDrivingSignalStatus = IsOn(gantryZDriving);
            // 실제 Y축 도착 입력 신호 상태를 표시합니다.
            gantryYAtDestinationSignalStatus = IsOn(gantryYAtDestination);
            // 실제 Z축 도착 입력 신호 상태를 표시합니다.
            gantryZAtDestinationSignalStatus = IsOn(gantryZAtDestination);
            // Y축 Drive 본체의 목표 위치를 표시합니다.
            gantryYDriveTargetPositionStatus = gantryYDrive != null ? gantryYDrive.TargetPosition : 0f;
            // Z축 Drive 본체의 목표 위치를 표시합니다.
            gantryZDriveTargetPositionStatus = gantryZDrive != null ? gantryZDrive.TargetPosition : 0f;
            // Y축 Drive 본체의 시작 상태를 표시합니다.
            gantryYDriveTargetStartStatus = gantryYDrive != null && gantryYDrive.TargetStartMove;
            // Z축 Drive 본체의 시작 상태를 표시합니다.
            gantryZDriveTargetStartStatus = gantryZDrive != null && gantryZDrive.TargetStartMove;
            // Y축 Drive 본체의 구동 상태를 표시합니다.
            gantryYDriveIsRunningStatus = gantryYDrive != null && gantryYDrive.IsRunning;
            // Z축 Drive 본체의 구동 상태를 표시합니다.
            gantryZDriveIsRunningStatus = gantryZDrive != null && gantryZDrive.IsRunning;
            // Y축 Drive 본체의 목표 도착 상태를 표시합니다.
            gantryYDriveIsAtTargetStatus = gantryYDrive != null && gantryYDrive.IsAtTarget;
            // Z축 Drive 본체의 목표 도착 상태를 표시합니다.
            gantryZDriveIsAtTargetStatus = gantryZDrive != null && gantryZDrive.IsAtTarget;
            // Y축 Drive 본체가 목적지 이동을 막고 있는지 표시합니다.
            gantryYDriveBlockDestinationStatus = gantryYDrive != null && gantryYDrive.BlockDestination;
            // Z축 Drive 본체가 목적지 이동을 막고 있는지 표시합니다.
            gantryZDriveBlockDestinationStatus = gantryZDrive != null && gantryZDrive.BlockDestination;
            gantryYDrivePathStatus = gantryYDrive != null ? GetHierarchyPath(gantryYDrive.transform) : "";
            gantryZDrivePathStatus = gantryZDrive != null ? GetHierarchyPath(gantryZDrive.transform) : "";
            gantryYDriveSmoothAccelerationStatus = gantryYDrive != null && gantryYDrive.SmoothAcceleration;
            gantryZDriveSmoothAccelerationStatus = gantryZDrive != null && gantryZDrive.SmoothAcceleration;
            // 현재 이동 명령 중 Y축 Start 신호가 한 번이라도 켜졌으면 true로 유지합니다.
            gantryYStartSeenThisMove = gantryYStartSeenThisMove || gantryYStartSignalStatus;
            // 현재 이동 명령 중 Z축 Start 신호가 한 번이라도 켜졌으면 true로 유지합니다.
            gantryZStartSeenThisMove = gantryZStartSeenThisMove || gantryZStartSignalStatus;
            // 현재 이동 명령 중 Y축 Driving 신호가 한 번이라도 켜졌으면 true로 유지합니다.
            gantryYDrivingSeenThisMove = gantryYDrivingSeenThisMove || gantryYDrivingSignalStatus;
            // 현재 이동 명령 중 Z축 Driving 신호가 한 번이라도 켜졌으면 true로 유지합니다.
            gantryZDrivingSeenThisMove = gantryZDrivingSeenThisMove || gantryZDrivingSignalStatus;
        }

        // 이동 관련 디버그 문자열을 만드는 메서드입니다.
        private string BuildMoveDebugText()
        {
            // 축별 도착/이동/시작/현재 위치 정보를 하나의 문자열로 조합합니다.
            return "YAt=" + IsOn(gantryYAtDestination)
                   + ", ZAt=" + IsOn(gantryZAtDestination)
                   + ", YDriving=" + IsOn(gantryYDriving)
                   + ", ZDriving=" + IsOn(gantryZDriving)
                   + ", YStart=" + IsOn(gantryYStart)
                   + ", ZStart=" + IsOn(gantryZStart)
                   + ", YPos=" + PositionText(gantryYCurrentPosition, targetPositionY)
                   + ", ZPos=" + PositionText(gantryZCurrentPosition, targetPositionZ);
        }

        // 현재 위치 신호와 목표 위치를 보기 좋은 문자열로 만드는 메서드입니다.
        private static string PositionText(PLCInputFloat signal, float target)
        {
            // 위치 신호가 연결되지 않았다면 연결되지 않았음을 표시합니다.
            if (signal == null)
            {
                // 연결 누락과 목표 위치를 함께 표시합니다.
                return "not connected/" + target.ToString("0.0");
            }

            // 현재 위치와 목표 위치를 현재/목표 형식으로 표시합니다.
            return signal.Value.ToString("0.0") + "/" + target.ToString("0.0");
        }

        private bool AxisAtTarget(Drive drive, PLCInputBool atDestinationSignal, PLCInputFloat positionSignal, float target)
        {
            if (drive != null)
            {
                float pos = positionSignal != null ? positionSignal.Value : drive.CurrentPosition;
                return drive.IsAtTarget && Mathf.Abs(pos - target) <= positionTolerance;
            }

            if (positionSignal != null)
            {
                return Mathf.Abs(positionSignal.Value - target) <= positionTolerance;
            }

            return IsOn(atDestinationSignal);
        }

        // 박스가 캔을 받을 준비가 되었는지 판단하는 메서드입니다.
        private bool BoxIsReadyForPlacing()
        {
            // 박스 컨베이어가 있고, 박스가 gantry 센서에 있으며, 컨베이어가 멈춰 있을 때 준비 완료로 판단합니다.
            return boxConveyor != null
                   && IsOn(boxConveyor.sensorGantryOccupied)
                   && !IsOn(boxConveyor.startConveyor);
        }

        // 캔을 하나 내려놓은 뒤 다음 박스 위치를 계산하는 메서드입니다.
        private void AdvanceBoxPattern()
        {
            // 다음 캔을 같은 행의 다음 열에 놓기 위해 열 번호를 증가시킵니다.
            currentColumnNumber++;

            // 열 번호가 설정된 열 수를 초과하면 다음 행으로 넘어갑니다.
            if (currentColumnNumber > numberOfColumns)
            {
                // 새 행의 첫 번째 열로 돌아갑니다.
                currentColumnNumber = 1;
                // 다음 행 번호로 증가시킵니다.
                currentRowNumber++;
                // 박스 컨베이어가 연결되어 있으면 다음 행 이동을 요청합니다.
                if (boxConveyor != null)
                {
                    // 박스 컨베이어에 다음 행 이동 거리를 전달합니다.
                    boxConveyor.nextRowDistance = distanceRow;
                    // 박스 컨베이어에 다음 행 이동 요청을 켭니다.
                    boxConveyor.driveNextRow = true;
                }
            }

            // 행 번호가 설정된 행 수를 초과하면 박스 교체 사이클을 시작합니다.
            if (currentRowNumber > numberOfRows)
            {
                // 행/열 번호를 초기화하고 박스 교체 요청을 켭니다.
                StartBoxChangeCycle();
            }

            // 캔 적재 완료 사이클 수를 1 증가시킵니다.
            cycleNumber++;
        }

        // 박스 교체 사이클을 시작하는 메서드입니다.
        private void StartBoxChangeCycle()
        {
            // 새 박스 기준으로 행 번호를 1로 초기화합니다.
            currentRowNumber = 1;
            // 새 박스 기준으로 열 번호를 1로 초기화합니다.
            currentColumnNumber = 1;
            // 박스 컨베이어가 연결되어 있으면 박스 교체 요청을 켭니다.
            if (boxConveyor != null)
            {
                // 박스 컨베이어에게 박스 교체 사이클을 요청합니다.
                boxConveyor.boxChangeCycle = true;
            }
        }

        // 지정한 시간이 지났는지 확인하는 지연 타이머 헬퍼 메서드입니다.
        private static bool DelayElapsed(ref float startedAt, float seconds)
        {
            // 타이머가 아직 시작되지 않았다면 현재 시간으로 시작합니다.
            if (startedAt <= 0f)
            {
                // 시작 시간을 현재 시간으로 저장합니다.
                startedAt = Time.time;
                // 첫 호출에서는 아직 시간이 지나지 않았다고 반환합니다.
                return false;
            }

            // 시작 후 지정한 시간이 아직 지나지 않았다면 대기합니다.
            if (Time.time - startedAt < seconds)
            {
                // 아직 지연 시간이 끝나지 않았다고 반환합니다.
                return false;
            }

            // 다음 지연 체크를 위해 시작 시간을 초기화합니다.
            startedAt = 0f;
            // 지연 시간이 끝났다고 반환합니다.
            return true;
        }

        // PLCInputBool 신호가 연결되어 있고 ON 상태인지 확인하는 헬퍼 메서드입니다.
        private static bool IsOn(PLCInputBool signal)
        {
            // 신호가 null이면 false로 보고, 연결되어 있으면 실제 Value를 반환합니다.
            return signal != null && signal.Value;
        }

        // PLCOutputBool 신호가 연결되어 있고 ON 상태인지 확인하는 헬퍼 메서드입니다.
        private static bool IsOn(PLCOutputBool signal)
        {
            // 신호가 null이면 false로 보고, 연결되어 있으면 실제 Value를 반환합니다.
            return signal != null && signal.Value;
        }

        // PLCInputFloat 신호 값을 안전하게 읽는 헬퍼 메서드입니다.
        private static float Value(PLCInputFloat signal)
        {
            // 신호가 null이면 0으로 보고, 연결되어 있으면 실제 Value를 반환합니다.
            return signal != null ? signal.Value : 0f;
        }

        // PLCOutputFloat 신호 값을 안전하게 읽는 헬퍼 메서드입니다.
        private static float Value(PLCOutputFloat signal)
        {
            // 신호가 null이면 0으로 보고, 연결되어 있으면 실제 Value를 반환합니다.
            return signal != null ? signal.Value : 0f;
        }

        // PLCOutputBool 신호가 null인지 확인한 뒤 안전하게 값을 쓰는 헬퍼 메서드입니다.
        private static void Set(PLCOutputBool signal, bool value)
        {
            // 신호 연결이 되어 있을 때만 값을 씁니다.
            if (signal != null)
            {
                // 실제 PLC 출력 신호 값을 변경합니다.
                signal.Value = value;
            }
        }

        // PLCOutputFloat 신호가 null인지 확인한 뒤 안전하게 값을 쓰는 헬퍼 메서드입니다.
        private static void Set(PLCOutputFloat signal, float value)
        {
            // 신호 연결이 되어 있을 때만 값을 씁니다.
            if (signal != null)
            {
                // 실제 PLC 출력 신호 값을 변경합니다.
                signal.Value = value;
            }
        }

        // 씬 안에서 특정 이름을 가진 PLC 신호 컴포넌트를 찾는 헬퍼 메서드입니다.
        private static T FindSceneSignal<T>(string objectName) where T : Component
        {
            // 비활성 오브젝트까지 포함해 해당 타입의 모든 컴포넌트를 찾습니다.
            T[] signals = Resources.FindObjectsOfTypeAll<T>();
            // 찾은 컴포넌트 목록을 하나씩 검사합니다.
            foreach (T signal in signals)
            {
                // 신호가 없거나 게임 오브젝트 이름이 원하는 이름과 다르면 건너뜁니다.
                if (signal == null || signal.gameObject.name != objectName)
                {
                    // 다음 후보를 검사합니다.
                    continue;
                }

                // 프로젝트 에셋이 아니라 실제 씬에 존재하는 오브젝트인지 확인합니다.
                if (!signal.gameObject.scene.IsValid())
                {
                    // 씬 오브젝트가 아니면 건너뜁니다.
                    continue;
                }

                // 조건을 만족하는 신호를 반환합니다.
                return signal;
            }

            // 원하는 신호를 찾지 못하면 null을 반환합니다.
            return null;
        }

        // 씬 안에서 특정 이름을 가진 realvirtual Drive 컴포넌트를 찾는 헬퍼 메서드입니다.
        private static Drive FindSceneDrive(string objectName)
        {
            // 비활성 오브젝트까지 포함해 모든 Drive 컴포넌트를 찾습니다.
            Drive[] drives = Resources.FindObjectsOfTypeAll<Drive>();
            // 찾은 Drive 목록을 하나씩 검사합니다.
            foreach (Drive drive in drives)
            {
                // Drive가 없거나 게임 오브젝트 이름이 원하는 이름과 다르면 건너뜁니다.
                if (drive == null || drive.gameObject.name != objectName)
                {
                    // 다음 후보를 검사합니다.
                    continue;
                }

                // 프로젝트 에셋이 아니라 실제 씬에 존재하는 오브젝트인지 확인합니다.
                if (!drive.gameObject.scene.IsValid())
                {
                    // 씬 오브젝트가 아니면 건너뜁니다.
                    continue;
                }

                // 조건을 만족하는 Drive를 반환합니다.
                return drive;
            }

            // 원하는 Drive를 찾지 못하면 null을 반환합니다.
            return null;
        }

        private static void ConfigureDriveForDemo(Drive drive)
        {
            if (drive == null)
            {
                return;
            }

            drive.SmoothAcceleration = false;
        }

        private static string GetHierarchyPath(Transform transform)
        {
            if (transform == null)
            {
                return "";
            }

            string path = transform.name;
            Transform current = transform.parent;

            while (current != null)
            {
                path = current.name + "/" + path;
                current = current.parent;
            }

            return path;
        }
    }
}
